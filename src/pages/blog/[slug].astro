---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = (await getCollection('blog'))
  .filter(p => p.slug !== post.slug && p.slug !== 'example')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedPosts = (() => {
  const same = allPosts.filter(p => p.data.category === post.data.category).slice(0, 3);
  if (same.length >= 3) return same;
  return [...same, ...allPosts.filter(p => p.data.category !== post.data.category).slice(0, 3 - same.length)];
})();

const tocHeadings = headings.filter(h => h.depth === 2);

const siteUrl = 'https://tsuyoshishirota.com';
const pageUrl = `${siteUrl}/blog/${post.slug}`;
const ogImage = post.data.coverImage.startsWith('http')
  ? post.data.coverImage
  : `${siteUrl}${post.data.coverImage}`;

const formattedDate = post.data.date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  image: ogImage,
  url: pageUrl,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Tsuyoshi Shirota',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'tsuyoshishirota.com',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
};

const reviewLd = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'LocalBusiness',
    name: post.data.facilityName || post.data.title,
    image: ogImage,
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: post.data.rating ?? 5,
    bestRating: 5,
    worstRating: 1,
  },
  author: {
    '@type': 'Organization',
    name: 'tsuyoshishirota.com',
    url: siteUrl,
  },
  reviewBody: post.data.excerpt,
  url: pageUrl,
  datePublished: post.data.date.toISOString(),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'ブログ', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: pageUrl },
  ],
};
---

<BaseLayout
  title={`${post.data.title} | tsuyoshishirota.com`}
  description={post.data.excerpt}
  ogImage={post.data.coverImage}
  ogType="article"
  canonicalUrl={pageUrl}
  publishedDate={post.data.date.toISOString()}
  jsonLd={jsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(reviewLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} slot="head" />
  <Header slot="header" />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- パンくずリスト -->
    <nav aria-label="パンくずリスト" class="mb-6 text-sm text-gray-500 flex items-center gap-2">
      <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
      <span>/</span>
      <a href="/blog" class="hover:text-blue-600 transition-colors">ブログ</a>
      <span>/</span>
      <span class="text-gray-700 line-clamp-1">{post.data.title}</span>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-sm font-medium px-3 py-1 bg-blue-50 text-blue-600 rounded-full">
          {post.data.category}
        </span>
        <time class="text-sm text-gray-400" datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6 leading-tight">
        {post.data.title}
      </h1>
      <div class="aspect-video rounded-xl overflow-hidden bg-gray-100">
        <img
          src={post.data.coverImage}
          alt={`${post.data.facilityName || post.data.title}のサウナ施設写真`}
          class="w-full h-full object-cover"
          onerror="this.src='/images/placeholder.jpg'"
        />
      </div>
    </div>

    <!-- 広告：記事上部 -->
    <div class="my-6">
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-3705985032450985"
        data-ad-slot="2115798309"
        data-ad-format="auto"
        data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 目次 -->
    {tocHeadings.length >= 3 && (
      <nav aria-label="目次" class="mb-10 p-5 bg-gray-50 rounded-xl border border-gray-200">
        <p class="text-sm font-bold text-gray-700 mb-3">目次</p>
        <ol class="space-y-1 list-decimal list-inside">
          {tocHeadings.map(h => (
            <li>
              <a href={`#${h.slug}`} class="text-sm text-blue-600 hover:underline">
                {h.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose prose-gray max-w-none
      prose-headings:font-bold prose-headings:text-gray-900
      prose-p:text-gray-700 prose-p:leading-relaxed
      prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
      prose-li:text-gray-700
      prose-strong:text-gray-900">
      <Content />
    </div>

    <!-- 広告：記事末尾 -->
    <div class="my-10">
      <ins class="adsbygoogle"
        style="display:block; text-align:center;"
        data-ad-client="ca-pub-3705985032450985"
        data-ad-slot="6229034219"
        data-ad-format="auto"
        data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 関連記事 -->
    {relatedPosts.length > 0 && (
      <div class="mt-16 pt-10 border-t border-gray-200">
        <h2 class="text-lg font-bold text-gray-900 mb-6">関連記事</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {relatedPosts.map(p => (
            <a href={`/blog/${p.slug}`} class="group block rounded-xl overflow-hidden border border-gray-200 hover:border-blue-300 transition-colors">
              <div class="aspect-video overflow-hidden bg-gray-100">
                <img
                  src={p.data.coverImage}
                  alt={`${p.data.facilityName || p.data.title}のサウナ施設写真`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  onerror="this.src='/images/placeholder.jpg'"
                  loading="lazy"
                />
              </div>
              <div class="p-3">
                <span class="text-xs text-blue-600 font-medium">{p.data.category}</span>
                <p class="text-sm font-semibold text-gray-800 mt-1 line-clamp-2 group-hover:text-blue-600 transition-colors">
                  {p.data.title}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-10 pt-8 border-t border-gray-200">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
      >
        ← ブログ一覧に戻る
      </a>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
